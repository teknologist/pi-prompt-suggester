{
  "name": "@guwidoe/pi-prompt-suggester",
  "version": "0.4.0",
  "type": "module",
  "description": "Intent-aware next-prompt suggestion extension for pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guwidoe/pi-prompt-suggester.git"
  },
  "homepage": "https://github.com/guwidoe/pi-prompt-suggester#readme",
  "bugs": {
    "url": "https://github.com/guwidoe/pi-prompt-suggester/issues"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "coding-agent",
    "terminal-agent",
    "ai-agent",
    "developer-tools",
    "prompt-suggester",
    "prompt-suggestion",
    "prompt-engineering",
    "workflow-automation",
    "productivity",
    "typescript"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc --noEmit",
